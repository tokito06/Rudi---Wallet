{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RuDi",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "windows": [
      {
        "title": "RuDi Wallet",
        "width": 400,
        "height": 750,
        "resizable": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
    "icons/128x128.png",
    "icons/icon.icns",
    "icons/icon.ico"
    ]
  }
}